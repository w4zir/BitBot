# Copy to .env and adjust. Used by docker compose and local runs.

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_HOST_SIMULATOR=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ecom_support
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme

# Elasticsearch (policy retrieval — see README)
ES_HOST=elasticsearch
ES_PORT=9200
ES_SCHEME=http
ES_POLICY_INDEX=policy_docs
ES_TIMEOUT_SECONDS=5

# ModernBERT classifier (BentoML container)
CLASSIFIER_BENTOML_URL=http://modernbert:3000/classify
CLASSIFIER_BENTOML_TIMEOUT_SECONDS=5
MODERNBERT_MODELS_HOST_DIR=./training/models
MODERNBERT_MODELS_CONTAINER_DIR=/training/models
MODERNBERT_MODEL_DIR=/training/models/bitext_multiclass_finetuned_20260415T120000Z/winner

# App
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8501

# Frontend → backend (compose overrides for in-network URL)
BACKEND_BASE_URL=http://localhost:8000

# Session + required-fields config (full_flow on POST /classify)
# ISSUE_REQUIRED_FIELDS_PATH=/app/backend/config/issue_required_fields.json
# PROCEDURES_DIR=/app/backend/procedures
CATEGORY_CONFIDENCE_THRESHOLD=0.5
AGENT_VALIDATION_MAX_USER_WAITS=5
AGENT_MAX_NODE_TURNS=20
AGENT_CHECKPOINT_DB=agent_checkpoints.db
AGENT_PERSISTENT_MODE=0

# LLM — no_issue branch (Ollama or Cerebras)
NO_ISSUE_MODEL_PROVIDER=ollama
NO_ISSUE_MODEL=llama3.2
# NO_ISSUE_SYSTEM_PROMPT=You are a helpful assistant...

# LLM — intent classification (scoped JSON intent; optional DB allowlist per category)
INTENT_MODEL_PROVIDER=ollama
INTENT_MODEL=llama3.2

# LLM — validation branch
VALIDATION_MODEL_PROVIDER=ollama
VALIDATION_MODEL=llama3.2

# Ollama (local). On Windows Docker, host.docker.internal reaches the host.
OLLAMA_BASE_URL=http://localhost:11434

# Cerebras (cloud) — only if provider is cerebras
# CEREBRAS_API_KEY=
# CEREBRAS_API_BASE=https://api.cerebras.ai/v1
CEREBRAS_TEMPERATURE=0.2

# Training/data scripts
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2
# CEREBRAS_MODEL=llama3.1-8b
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# OLLAMA_API_KEY=ollama

# LLM_HTTP_TIMEOUT_SECONDS=120
LLM_TIMEOUT_SECONDS=120
